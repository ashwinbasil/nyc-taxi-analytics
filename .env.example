# MySQL Configuration

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root_password
MYSQL_DATABASE=nyc_taxi

# Data Pipeline Settings

BATCH_SIZE=10000
MAX_WORKERS=4
LOG_LEVEL=INFO
DATA_PATH=./data

# NYC Taxi Dataset (BigQuery)

BIGQUERY_PROJECT=bigquery-public-data
BIGQUERY_DATASET=new_york_taxi
BIGQUERY_TABLE=tlc_yellow_trips_2019

# Date Range for Initial Load (YYYY-MM-DD format)

START_DATE=2019-01-01
END_DATE=2019-12-31

# Scheduling

ENABLE_SCHEDULER=false
SCHEDULE_HOUR=2
SCHEDULE_MINUTE=0
